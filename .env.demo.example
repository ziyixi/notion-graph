# Demo mode uses local fixture data and does not call real Notion APIs.

NOTION_TOKEN=demo_token_not_used
NOTION_ROOT_PAGE_ID=root_page

DATABASE_URL=sqlite:////data/notion_graph.db
SYNC_INTERVAL_MINUTES=360
SYNC_POLL_SECONDS=10
CORS_ORIGINS=http://localhost:3000
ADMIN_API_KEY=demo_admin_key
NOTION_WEBHOOK_SECRET=demo_webhook_secret
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0

NOTION_USE_FIXTURES=true
NOTION_FIXTURE_PATH=/app/tests/fixtures/notion_fixture.json

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
