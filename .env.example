# Backend Notion runtime (optional: can be set in /admin and stored in DB)
NOTION_TOKEN=
NOTION_ROOT_PAGE_ID=

# Backend runtime
DATABASE_URL=sqlite:////data/notion_graph.db
SYNC_INTERVAL_MINUTES=360
SYNC_POLL_SECONDS=10
CORS_ORIGINS=http://localhost:3000
ADMIN_API_KEY=change_me_admin_key
NOTION_WEBHOOK_SECRET=
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0

# Optional local fixture mode
NOTION_USE_FIXTURES=false
NOTION_FIXTURE_PATH=/app/tests/fixtures/notion_fixture.json

# Web runtime
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
